# ─── JobIQ Environment Variables ──────────────────────────────────────────────
# Copy this file to .env.local and fill in the values you need.
# Every variable is optional — the app runs in full demo mode without any keys.

# ── AI Analysis ───────────────────────────────────────────────────────────────
# Free API key from https://openrouter.ai
# Without this, the app uses local regex analysis (works fine for demo).
OPENROUTER_API_KEY=

# ── Scraping Mode ─────────────────────────────────────────────────────────────
# Set to "false" to enable live cheerio scraping from onlinejobs.ph.
# Default is "true" (safe for Vercel deployment — uses realistic mock data).
# For live scraping you also need ONLINEJOBS_SESSION_COOKIE below.
DEMO_MODE=true

# ── OnlineJobs.ph Session Cookie ──────────────────────────────────────────────
# Required only when DEMO_MODE=false.
# Steps to get it:
#   1. Log in to onlinejobs.ph in your browser
#   2. Open DevTools → Application → Cookies
#   3. Copy the value of the "ci_session" cookie
ONLINEJOBS_SESSION_COOKIE=

# ── Email Delivery (optional — simulated if not set) ─────────────────────────
# Gmail SMTP with an App Password.
# Steps to get an App Password:
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate a password for "Mail"
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Recipient email — defaults to dekuallmight1234@gmail.com if not set
TO_EMAIL=dekuallmight1234@gmail.com
